# =============================================================
#  Bizreach Auto Scout — 環境変数サンプル
#  このファイルを .env にコピーして値を設定してください。
#  .env は .gitignore 済み（コミットしないこと）。
# =============================================================

# --- Claude (Anthropic) API -------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# 文面生成に使うモデル。品質重視なら opus、コスト/速度重視なら sonnet。
BIZSCOUT_MODEL=claude-opus-4-8

# --- Bizreach ログイン情報（ブラウザ自動操作を使う場合のみ）-----------------
BIZREACH_EMAIL=your-recruiter-account@example.com
BIZREACH_PASSWORD=your-password
# ログインセッションの保存先（再ログインを避けるため）
BIZREACH_STORAGE_STATE=data/sessions/bizreach_state.json

# --- 送信制御 ----------------------------------------------------------------
# true の場合、実際の送信は行わず生成・保存のみ（強く推奨：まずはこれで検証）
BIZSCOUT_DRY_RUN=true
# 1回の実行で送信する最大件数（暴走防止）
BIZSCOUT_MAX_SENDS_PER_RUN=20
# 送信間の待機秒数の下限・上限（人間的な間隔・レート制限対策）
BIZSCOUT_SEND_DELAY_MIN=20
BIZSCOUT_SEND_DELAY_MAX=60
# このパスにファイルが存在する間は一切送信しない緊急停止スイッチ
BIZSCOUT_KILL_SWITCH=data/state/STOP

# --- 再送スケジュール --------------------------------------------------------
# 初回送信から何日後に再送するか
BIZSCOUT_RESEND_AFTER_DAYS=5

# --- パス類（通常は変更不要）------------------------------------------------
BIZSCOUT_HOME=.
BIZSCOUT_DB_PATH=data/bizscout.db
